# PreLend — .env (не коммитить в гит!)
# Скопируй этот файл в .env и заполни значения.

# ── Telegram ─────────────────────────────────────────────────────────────────
# Тот же токен что у ShortsProject и Orchestrator (один чат).
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Whitelist user_id (через запятую). Если пусто — разрешены все из CHAT_ID
TELEGRAM_ALLOWED_USER_IDS=

# ── Режим Orchestrator ────────────────────────────────────────────────────────
# Когда Orchestrator запущен — выставить оба флага в true:
#   polling берёт на себя Orchestrator, дайджест берёт на себя Orchestrator.
#   Критические алерты (лендинг упал, пиковый бот%) отправляются всегда через alert().
PL_DISABLE_TELEGRAM_POLLING=false
PL_TELEGRAM_CRITICAL_ONLY=false
PL_DISABLE_DAILY_DIGEST=false

# ── Ollama (локальный адрес на ПК разработчика) ───────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-vl:7b

# ── Пути к проектам (для telegram_router.py на ПК разработчика) ──────────────
PRELEND_PATH=/path/to/PreLend
SHORTS_PROJECT_PATH=/path/to/ShortsProject

# ── PreLend paths (на VPS — используются в PHP и cron-скриптах) ──────────────
PRELEND_DB=/var/www/prelend/data/clicks.db
PRELEND_LOG=/var/www/prelend/logs/errors.log

# ── PreLend Internal API ──────────────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО! Без этого API работает без авторизации.
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
PL_INTERNAL_API_KEY=   # ОБЯЗАТЕЛЬНО задать перед деплоем!
PL_INTERNAL_HOST=127.0.0.1
PL_INTERNAL_PORT=9090
